DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
# Also the fallback signing secret for local-agent JWTs (see server/src/agent-auth-jwt.ts). These
# tokens let adapter agents — including the `opensage` adapter's per-run control-plane tools — call
# the Paperclip API. Override with a strong PAPERCLIP_AGENT_JWT_SECRET in production.
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
