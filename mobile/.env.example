# Paperclip mobile (Aurora) build-time env. The app AUTO-CONNECTS to this backend at launch — there
# is no in-app Connect screen — so these values are the real endpoint, not just a placeholder.
# Committed defaults live in `.env` (localhost); copy to `.env.local` (gitignored, per-machine) to
# override with a setup-specific host without committing it. Expo inlines EXPO_PUBLIC_* into the
# build; restart Metro / rebuild after changes.

# Backend the app auto-connects to. Defaults to http://localhost:3100 (see committed .env). To point
# a build at a specific box over Tailscale, use its MagicDNS name:
#   EXPO_PUBLIC_API_BASE_URL=http://<host>.<tailnet>.ts.net:3100
EXPO_PUBLIC_API_BASE_URL=http://localhost:3100

# Optional bearer token sent with the auto-connect. Leave unset for local_trusted boards (no auth).
#   EXPO_PUBLIC_API_TOKEN=<token>

# iOS only: if EXPO_PUBLIC_API_BASE_URL is a plaintext http:// host other than localhost (e.g. a
# Tailscale .ts.net name), set the domain here to add a scoped App Transport Security exception
# (tailnet traffic is already WireGuard-encrypted). Requires a native rebuild (expo prebuild / dev
# build). Leave unset for https or localhost.
#   EXPO_PUBLIC_ATS_INSECURE_DOMAIN=<tailnet>.ts.net
