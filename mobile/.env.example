# Paperclip mobile (Aurora) build-time env. Copy to `.env.local` (gitignored) and fill in your
# own values — `.env.local` is per-machine and never committed, so setup-specific hostnames stay
# out of git. Expo inlines EXPO_PUBLIC_* into the build; restart Metro / rebuild after changes.

# Backend the app targets by default. Leave unset to default to http://localhost:3100. To point a
# build at a specific box over Tailscale, use its MagicDNS name:
#   EXPO_PUBLIC_API_BASE_URL=http://<host>.<tailnet>.ts.net:3100
EXPO_PUBLIC_API_BASE_URL=http://localhost:3100

# iOS only: if EXPO_PUBLIC_API_BASE_URL is a plaintext http:// host other than localhost (e.g. a
# Tailscale .ts.net name), set the domain here to add a scoped App Transport Security exception
# (tailnet traffic is already WireGuard-encrypted). Requires a native rebuild (expo prebuild / dev
# build). Leave unset for https or localhost.
#   EXPO_PUBLIC_ATS_INSECURE_DOMAIN=<tailnet>.ts.net
